<!-- =============== TWEAKS =============== -->
<div id="tweaks" class="">
  <h5>TWEAKS <span style="color:#ffd23f;font-size:10px;">//KEBA</span></h5>
  <label>Theme</label>
  <div class="themes">
    <div class="theme-sw active" data-theme="pitch" title="Pitch"><i style="background:#0f2e1a"></i><i style="background:#ffd23f"></i></div>
    <div class="theme-sw" data-theme="asphalt" title="Asphalt"><i style="background:#0a0a0a"></i><i style="background:#ff3d00"></i></div>
    <div class="theme-sw" data-theme="sunset" title="Sunset"><i style="background:#1a1630"></i><i style="background:#ff006e"></i></div>
    <div class="theme-sw" data-theme="concrete" title="Concrete"><i style="background:#e8e2d4"></i><i style="background:#c8372d"></i></div>
  </div>
  <label>Hero layout</label>
  <select id="tw-hero">
    <option value="split">Split (default)</option>
    <option value="centered">Centered megatitle</option>
    <option value="stacked">Stacked vertical</option>
  </select>
  <label>Texture intensity</label>
  <input type="range" id="tw-grain" min="0" max="60" step="1">
  <label>Show badge</label>
  <select id="tw-badge">
    <option value="on">On</option>
    <option value="off">Off</option>
  </select>
</div>
<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
  /* =========================
     TWEAKS
     ========================= */
  const TWEAK_DEFAULTS = /*EDITMODE-BEGIN*/{
    "theme": "pitch",
    "hero": "split",
    "grain": 26,
    "badge": "on"
  }/*EDITMODE-END*/;

  const state = Object.assign({}, TWEAK_DEFAULTS);

  function applyTheme(t){
    document.documentElement.setAttribute('data-theme', t);
    document.querySelectorAll('#tweaks .theme-sw').forEach(el => {
      el.classList.toggle('active', el.dataset.theme === t);
    });
  }
  function applyHero(h){
    const body = document.querySelector('.hero__body');
    const title = document.querySelector('.hero__title');
    const side = document.querySelector('.hero__side');
    if(!body) return;
    if(h === 'centered'){
      body.style.gridTemplateColumns = '1fr';
      body.style.textAlign = 'center';
      side.style.alignItems = 'center';
      title.style.fontSize = 'clamp(100px, 24vw, 420px)';
    } else if(h === 'stacked'){
      body.style.gridTemplateColumns = '1fr';
      body.style.textAlign = 'left';
      side.style.alignItems = 'flex-start';
      title.style.fontSize = 'clamp(90px, 20vw, 360px)';
    } else {
      body.style.gridTemplateColumns = '1.2fr 1fr';
      body.style.textAlign = 'left';
      side.style.alignItems = 'flex-start';
      title.style.fontSize = '';
    }
  }
  function applyGrain(g){
    document.documentElement.style.setProperty('--grain-op', (g/100).toFixed(2));
  }
  function applyBadge(b){
    const el = document.querySelector('.hero__badge');
    if(el) el.style.display = (b === 'off') ? 'none' : '';
  }
  function applyAll(){
    applyTheme(state.theme);
    applyHero(state.hero);
    applyGrain(state.grain);
    applyBadge(state.badge);
    const set = (id, v) => { const e = document.getElementById(id); if(e) e.value = v; };
    set('tw-hero', state.hero);
    set('tw-grain', state.grain);
    set('tw-badge', state.badge);
  }
  function persist(patch){
    try {
      window.parent.postMessage({type:'__edit_mode_set_keys', edits: patch}, '*');
    } catch(e){}
  }

  // wiring
  document.querySelectorAll('#tweaks .theme-sw').forEach(el => {
    el.addEventListener('click', () => {
      state.theme = el.dataset.theme;
      applyTheme(state.theme);
      persist({theme: state.theme});
    });
  });
  document.addEventListener('change', e => {
    if(e.target.id === 'tw-hero'){ state.hero = e.target.value; applyHero(state.hero); persist({hero: state.hero}); }
    if(e.target.id === 'tw-badge'){ state.badge = e.target.value; applyBadge(state.badge); persist({badge: state.badge}); }
  });
  document.addEventListener('input', e => {
    if(e.target.id === 'tw-grain'){ state.grain = +e.target.value; applyGrain(state.grain); persist({grain: state.grain}); }
  });

  // edit mode plumbing
  window.addEventListener('message', (ev) => {
    const d = ev.data || {};
    if(d.type === '__activate_edit_mode') document.getElementById('tweaks').classList.add('open');
    if(d.type === '__deactivate_edit_mode') document.getElementById('tweaks').classList.remove('open');
  });
  try { window.parent.postMessage({type:'__edit_mode_available'}, '*'); } catch(e){}

  applyAll();

  // smooth scroll for nav
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', (e) => {
      const id = a.getAttribute('href');
      if(id.length > 1){
        const tgt = document.querySelector(id);
        if(tgt){ e.preventDefault(); window.scrollTo({top: tgt.offsetTop - 60, behavior: 'smooth'}); }
      }
    });
  });
</script>
